generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  LEAD
  MEMBER
}

enum OKRStatus {
  DRAFT
  SUBMITTED
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  password       String?
  image          String?
  googleEmail    String?      @unique
  role           Role         @default(MEMBER)
  division       String?
  hasOnboarded   Boolean      @default(true)
  isApproved     Boolean      @default(true)
  objectives     Objective[]
  teamMembers    TeamMember[] @relation("LeadTeamMembers")
  teamMembership TeamMember?  @relation("MemberUserLink")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Division {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Quarter {
  id              String             @id @default(cuid())
  name            String
  year            Int
  quarter         Int
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean            @default(false)
  objectives      Objective[]
  reminderSchedules ReminderSchedule[]
  createdAt       DateTime           @default(now())

  @@unique([year, quarter])
}

model ReminderSchedule {
  id         String    @id @default(cuid())
  type       String    // "settings" | "collection"
  quarterId  String
  quarter    Quarter   @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  frequency  String    // "weekly" | "biweekly" | "monthly"
  dayOfWeek  Int?      // 0=Sun 1=Mon ... 6=Sat  (weekly/biweekly)
  dayOfMonth Int?      // 1-28 (monthly)
  hourWIB    Int       // 0-23 Jakarta time
  isActive   Boolean   @default(true)
  lastRun    DateTime?
  nextRun    DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Objective {
  id          String                @id @default(cuid())
  title       String
  weight      Float                 @default(100)
  status      OKRStatus             @default(DRAFT)
  submittedAt DateTime?
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quarterId   String
  quarter     Quarter               @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  keyResults  KeyResult[]
  assignments ObjectiveAssignment[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model TeamMember {
  id          String                @id @default(cuid())
  name        String
  leadId      String
  lead        User                  @relation("LeadTeamMembers", fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?               @unique
  user        User?                 @relation("MemberUserLink", fields: [userId], references: [id], onDelete: SetNull)
  assignments ObjectiveAssignment[]
  createdAt   DateTime              @default(now())
}

model ObjectiveAssignment {
  id            String         @id @default(cuid())
  weight        Float
  memberId      String
  member        TeamMember     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  objectiveId   String
  objective     Objective      @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  krAssignments KRAssignment[]

  @@unique([memberId, objectiveId])
}

model KRAssignment {
  id           String              @id @default(cuid())
  weight       Float               @default(0)
  progress     Float               @default(0)
  target       Float?              // Individual target override (null = use parent KR target)
  assignmentId String
  assignment   ObjectiveAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  keyResultId  String
  keyResult    KeyResult           @relation(fields: [keyResultId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, keyResultId])
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  division  String?
  position  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KeyResult {
  id            String         @id @default(cuid())
  title         String
  target        Float
  unit          String
  weight        Float
  teamProgress  Float          @default(0)
  leadProgress  Float?
  objectiveId   String
  objective     Objective      @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  krAssignments KRAssignment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
