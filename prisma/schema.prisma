generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  LEAD
  MEMBER
}

enum OKRStatus {
  DRAFT
  SUBMITTED
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        Role         @default(MEMBER)
  division    String?
  objectives  Objective[]
  teamMembers TeamMember[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Quarter {
  id         String      @id @default(cuid())
  name       String
  year       Int
  quarter    Int
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean     @default(false)
  objectives Objective[]
  createdAt  DateTime    @default(now())

  @@unique([year, quarter])
}

model Objective {
  id          String                @id @default(cuid())
  title       String
  weight      Float                 @default(100)
  status      OKRStatus             @default(DRAFT)
  submittedAt DateTime?
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quarterId   String
  quarter     Quarter               @relation(fields: [quarterId], references: [id], onDelete: Cascade)
  keyResults  KeyResult[]
  assignments ObjectiveAssignment[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model TeamMember {
  id          String                @id @default(cuid())
  name        String
  leadId      String
  lead        User                  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignments ObjectiveAssignment[]
  createdAt   DateTime              @default(now())
}

model ObjectiveAssignment {
  id            String         @id @default(cuid())
  weight        Float
  memberId      String
  member        TeamMember     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  objectiveId   String
  objective     Objective      @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  krAssignments KRAssignment[]

  @@unique([memberId, objectiveId])
}

model KRAssignment {
  id           String              @id @default(cuid())
  weight       Float               @default(0)
  assignmentId String
  assignment   ObjectiveAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  keyResultId  String
  keyResult    KeyResult           @relation(fields: [keyResultId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, keyResultId])
}

model KeyResult {
  id            String         @id @default(cuid())
  title         String
  target        Float
  unit          String
  weight        Float
  teamProgress  Float          @default(0)
  leadProgress  Float?
  objectiveId   String
  objective     Objective      @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  krAssignments KRAssignment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}
